{
  "name": "@cypress/plugin-accessibility-warnings",
  "version": "0.0.0-development",
  "description": "Warn about a range of potential semantic HTML issues in what you test",
  "main": "src/index.js",
  "scripts": {
    "check-ts": "tsc --noEmit",
    "cy:open": "node ../../scripts/cypress.js open",
    "cy:run": "node ../../scripts/cypress.js run"
  },
  "devDependencies": {
    "cypress": "0.0.0-development"
  },
  "peerDependencies": {
    "cypress": "*"
  },
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cypress-io/cypress.git"
  },
  "homepage": "https://github.com/cypress-io/cypress/blob/develop/npm/plugin-accessibility-warnings/#readme",
  "keywords": [
    "accessibility",
    "cypress",
    "cypress-io",
    "test",
    "testing"
  ],
  "standard": {
    "globals": [
      "Cypress",
      "cy",
      "expect"
    ]
  }
}
